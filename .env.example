APP_NAME="Alta-Trade"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
DB_DATABASE=database/database.sqlite
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_ADMIN_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT=60
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=2000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ADDONS_REGISTRY_ENABLED=false
ADDONS_REGISTRY_URL=
ADDONS_REGISTRY_ALLOWED_HOSTS=
ADDONS_REGISTRY_TIMEOUT=5
ADDONS_REGISTRY_CACHE_TTL=3600
ADDONS_REGISTRY_VERIFY_SSL=true
ADDONS_REGISTRY_ALLOW_LOCALHOST=true
ADDONS_REGISTRY_DOWNLOADS_ENABLED=false
ADDONS_REGISTRY_DOWNLOAD_DISK=addons
ADDONS_REGISTRY_QUARANTINE_PATH=addons/quarantine
ADDONS_REGISTRY_MAX_ARTIFACT_SIZE=20971520
ADDONS_REGISTRY_REQUIRE_SIGNATURE=true
ADDONS_REGISTRY_REVIEW_ENABLED=true
ADDONS_REGISTRY_REVIEW_REQUIRE_TRUSTED=true
ADDONS_REGISTRY_REVIEW_REQUIRE_NOTE_ON_REJECT=true
ADDONS_REGISTRY_REVIEW_ALLOW_REVOKE=true
ADDONS_REGISTRY_STAGING_ENABLED=false
ADDONS_REGISTRY_STAGING_DISK=addons
ADDONS_REGISTRY_STAGING_PATH=addons/staging
ADDONS_REGISTRY_STAGING_REQUIRE_TRUSTED=true
ADDONS_REGISTRY_STAGING_REQUIRE_APPROVED=true
ADDONS_REGISTRY_STAGING_BLOCK_STALE=true
ADDONS_REGISTRY_STAGING_MAX_ENTRIES=2000
ADDONS_REGISTRY_STAGING_MAX_UNCOMPRESSED_SIZE=104857600
ADDONS_REGISTRY_STAGING_MAX_FILE_SIZE=20971520
ADDONS_REGISTRY_STAGING_MAX_COMPRESSION_RATIO=100
ADDONS_REGISTRY_STAGING_MAX_PATH_LENGTH=240
ADDONS_REGISTRY_PROMOTION_ENABLED=false
ADDONS_REGISTRY_LIVE_MODULES_PATH=/absolute/path/to/your/project/storage/app/addons/manual-live/modules
ADDONS_REGISTRY_LIVE_EXTENSIONS_PATH=/absolute/path/to/your/project/storage/app/addons/manual-live/extensions
ADDONS_REGISTRY_PROMOTION_REQUIRE_TRUSTED=true
ADDONS_REGISTRY_PROMOTION_REQUIRE_APPROVED=true
ADDONS_REGISTRY_PROMOTION_REQUIRE_STAGED=true
ADDONS_REGISTRY_PROMOTION_BLOCK_STALE_APPROVAL=true
ADDONS_REGISTRY_PROMOTION_BLOCK_STALE_STAGING=true
ADDONS_REGISTRY_PROMOTION_BACKUP_ENABLED=true
ADDONS_REGISTRY_PROMOTION_BACKUP_DISK=addons
ADDONS_REGISTRY_PROMOTION_BACKUP_PATH=addons/backups
ADDONS_REGISTRY_PROMOTION_JOURNAL_DISK=addons
ADDONS_REGISTRY_PROMOTION_JOURNAL_PATH=addons/promotion-journal
ADDONS_REGISTRY_PROMOTION_LOCK_TIMEOUT=30
ADDONS_REGISTRY_PROMOTION_KEEP_BACKUPS=5
ADDONS_REGISTRY_CLEANUP_ENABLED=false
ADDONS_REGISTRY_BACKUP_RETENTION_MIN_COUNT=1
ADDONS_REGISTRY_BACKUP_RETENTION_MAX_COUNT=5
ADDONS_REGISTRY_BACKUP_RETENTION_DAYS=30
ADDONS_REGISTRY_STALE_CLEANUP_AFTER=86400
